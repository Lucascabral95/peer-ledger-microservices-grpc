# Gateway
PORT=8080
USER_SERVICE_GRPC_ADDR=user-service:50051
FRAUD_SERVICE_GRPC_ADDR=fraud-service:50052
WALLET_SERVICE_GRPC_ADDR=wallet-service:50053
TRANSACTION_SERVICE_GRPC_ADDR=transaction-service:50054
AUTH_JWT_SECRET=change-this-secret-to-at-least-32-characters
AUTH_JWT_ISSUER=peer-ledger-gateway
AUTH_JWT_TTL=24h
GATEWAY_GRPC_DIAL_TIMEOUT=3s
GATEWAY_GRPC_MAX_ATTEMPTS=10
GATEWAY_METRICS_ENABLED=true
GATEWAY_METRICS_PATH=/metrics
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_DEFAULT_REQUESTS=120
GATEWAY_RATE_LIMIT_DEFAULT_WINDOW=1m
GATEWAY_RATE_LIMIT_TRANSFERS_REQUESTS=20
GATEWAY_RATE_LIMIT_TRANSFERS_WINDOW=1m
GATEWAY_RATE_LIMIT_CLEANUP_INTERVAL=2m
GATEWAY_RATE_LIMIT_TRUST_PROXY=false
GATEWAY_RATE_LIMIT_EXEMPT_PATHS=/health,/ping,/metrics
GATEWAY_GRACEFUL_SHUTDOWN_TIMEOUT=10s
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Fraud Service
FRAUD_GRPC_PORT=50052
FRAUD_PER_TX_LIMIT=20000
FRAUD_DAILY_LIMIT=50000
FRAUD_VELOCITY_MAX_COUNT=5
FRAUD_VELOCITY_WINDOW=10m
FRAUD_PAIR_COOLDOWN=30s
FRAUD_IDEMPOTENCY_TTL=24h
FRAUD_TIMEZONE=America/Argentina/Buenos_Aires
FRAUD_CLEANUP_INTERVAL=1m

# Wallet Service
WALLET_GRPC_PORT=50053
WALLET_DB_DSN=postgres://youruser:yoursecret@postgres:5432/wallets_db?sslmode=disable
WALLET_DB_MAX_OPEN_CONNS=25
WALLET_DB_MAX_IDLE_CONNS=10
WALLET_DB_CONN_MAX_LIFETIME=30m
WALLET_DB_CONN_MAX_IDLE_TIME=5m
WALLET_DB_CONNECT_TIMEOUT=3s
WALLET_DB_CONNECT_MAX_RETRIES=8
WALLET_DB_CONNECT_INITIAL_BACKOFF=500ms
WALLET_DB_CONNECT_MAX_BACKOFF=8s

# Transaction Service
TRANSACTION_GRPC_PORT=50054
TRANSACTION_DB_DSN=postgres://youruser:yoursecret@postgres:5432/transactions_db?sslmode=disable
TRANSACTION_DB_MAX_OPEN_CONNS=25
TRANSACTION_DB_MAX_IDLE_CONNS=10
TRANSACTION_DB_CONN_MAX_LIFETIME=30m
TRANSACTION_DB_CONN_MAX_IDLE_TIME=5m
TRANSACTION_DB_CONNECT_TIMEOUT=3s
TRANSACTION_DB_CONNECT_MAX_RETRIES=8
TRANSACTION_DB_CONNECT_INITIAL_BACKOFF=500ms
TRANSACTION_DB_CONNECT_MAX_BACKOFF=8s

# User Service
GRPC_PORT=50051
USER_DB_DSN=postgres://youruser:yoursecret@postgres:5432/users_db?sslmode=disable
USER_PASSWORD_HASH_ITERATIONS=120000
USER_PASSWORD_MIN_LENGTH=8
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
DB_CONNECT_TIMEOUT=3s
DB_CONNECT_MAX_RETRIES=8
DB_CONNECT_INITIAL_BACKOFF=500ms
DB_CONNECT_MAX_BACKOFF=8s
GRACEFUL_SHUTDOWN_TIMEOUT=10s

# Postgres
POSTGRES_USER=youruser
POSTGRES_PASSWORD=yoursecret
POSTGRES_DB=postgres
