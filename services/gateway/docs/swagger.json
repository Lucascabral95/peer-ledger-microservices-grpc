                "error": {
                    "type": "boolean",
                    "example": true
                },
                "message": {
                    "type": "string",
                    "example": "transfer blocked by fraud service"
                }
            }
        },
        "main.GetHistoryData": {
            "type": "object",
            "properties": {
                "records": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.TransactionRecordDTO"
                    }
                },
                "user_id": {
                    "type": "string",
                    "example": "user-001"
                }
