# Copy this file to project/deploy.local.env and fill the sensitive values.
# project/deploy.local.env is intentionally ignored by git.

AWS_PROFILE=default
AWS_REGION=us-east-1

TF_PROJECT_NAME=peer-ledger
TF_ENVIRONMENT=production
TF_LOCK_TABLE=peer-ledger-terraform-locks
TF_FOUNDATION_STATE_KEY=foundation/terraform.tfstate
TF_PLATFORM_STATE_KEY=platform/terraform.tfstate
TF_SERVICES_STATE_KEY=services/terraform.tfstate

# Optional. If empty, deploy-all.sh uses peer-ledger-tfstate-<current AWS account id>.
# TF_STATE_BUCKET=peer-ledger-tfstate-123456789012

# Required. Values are written to AWS Secrets Manager by the foundation stack.
AUTH_JWT_SECRET=replace-with-at-least-32-characters
RDS_MASTER_USERNAME=peerledger
RDS_MASTER_PASSWORD=replace-with-rds-password

# Optional. If empty, the current git commit SHA is used.
# SERVICE_IMAGE_TAG=
